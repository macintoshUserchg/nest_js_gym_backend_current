# =============================================================================
# Gym Management System - Environment Configuration Template
# =============================================================================
# Copy this file to .env and update with your actual values
# NEVER commit .env to version control
# =============================================================================

# -----------------------------------------------------------------------------
# JWT Configuration
# -----------------------------------------------------------------------------
# Generate secure secret: openssl rand -base64 32
JWT_SECRET=your-secure-random-secret-min-32-characters
JWT_EXPIRES_IN=1d

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
PORT=3000
NODE_ENV=development

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# Format: postgresql://user@host:port/database
POSTGRES_URL=postgresql://chandangaur@localhost:5432/gym_db
DATABASE_URL=postgresql://chandangaur@localhost:5432/gym_db

# -----------------------------------------------------------------------------
# Optional: PostgreSQL Password (if not using .pgpass)
# -----------------------------------------------------------------------------
# PGPASSWORD=your-database-password

# -----------------------------------------------------------------------------
# MinIO Configuration
# -----------------------------------------------------------------------------
# MinIO endpoint (host:port)
MINIO_ENDPOINT=localhost:9000
# MinIO access key (default: minioadmin)
MINIO_ACCESS_KEY=minioadmin
# MinIO secret key (default: minioadmin)
MINIO_SECRET_KEY=minioadmin
# MinIO bucket name for media storage
MINIO_BUCKET=gym-media
# Public URL for accessing MinIO files
MINIO_PUBLIC_URL=http://localhost:9000
# Use SSL for MinIO connection (true/false)
MINIO_USE_SSL=false

# -----------------------------------------------------------------------------
# Upload Limits
# -----------------------------------------------------------------------------
# Maximum file size in bytes (default: 10MB)
MAX_FILE_SIZE=10485760

# -----------------------------------------------------------------------------
# MinIO Configuration
# -----------------------------------------------------------------------------
# MinIO endpoint (host:port)
MINIO_ENDPOINT=localhost:9000
# MinIO access key (default: minioadmin)
MINIO_ACCESS_KEY=minioadmin
# MinIO secret key (default: minioadmin)
MINIO_SECRET_KEY=minioadmin
# MinIO bucket name for media storage
MINIO_BUCKET=gym-media
# Public URL for accessing MinIO files
MINIO_PUBLIC_URL=http://localhost:9000
# Use SSL for MinIO connection (true/false)
MINIO_USE_SSL=false

# -----------------------------------------------------------------------------
# Upload Limits
# -----------------------------------------------------------------------------
# Maximum file size in bytes (default: 10MB)
MAX_FILE_SIZE=10485760
