# =============================================================================
# Gym Management System - Environment Configuration Template
# =============================================================================
# Copy this file to .env and update with your actual values
# NEVER commit .env to version control
# =============================================================================

# -----------------------------------------------------------------------------
# JWT Configuration
# -----------------------------------------------------------------------------
# Generate secure secret: openssl rand -base64 32
JWT_SECRET=your-secure-random-secret-min-32-characters
JWT_EXPIRES_IN=1d

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
PORT=3000
NODE_ENV=development

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# Format: postgresql://user@host:port/database
POSTGRES_URL=postgresql://chandangaur@localhost:5432/gym_db
DATABASE_URL=postgresql://chandangaur@localhost:5432/gym_db

# -----------------------------------------------------------------------------
# Optional: PostgreSQL Password (if not using .pgpass)
# -----------------------------------------------------------------------------
# PGPASSWORD=your-database-password
