{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"],
      "env": {
        "DEFAULT_MINIMUM_TOKENS": ""
      }
    },
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/Users/chandangaur/development/Nest JS/new-nestjs-gym-app"],
      "alwaysAllow": [
        "read_text_file",
        "write_file",
        "create_directory",
        "list_directory",
        "search_files"
      ]
    },
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "alwaysAllow": [
        "create_entities",
        "search_nodes",
        "add_observations",
        "create_relations",
        "read_graph",
        "delete_entities",
        "delete_relations",
        "delete_observations",
        "open_nodes"
      ]
    },
    "fetch": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-fetch"],
      "alwaysAllow": ["fetch"]
    },
    "brave-search": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-brave-search"],
      "env": {
        "BRAVE_API_KEY": ""
      },
      "alwaysAllow": ["brave_web_search"]
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_TOKEN": ""
      },
      "alwaysAllow": [
        "create_or_update_file",
        "create_issue",
        "create_pull_request",
        "fork_repository",
        "push_files"
      ]
    }
  }
}
